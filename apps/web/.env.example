# Thirdweb — create a free account at https://thirdweb.com/dashboard
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=

# Mantle Sepolia RPC (public endpoint, override with your own for production)
NEXT_PUBLIC_MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz
NEXT_PUBLIC_CHAIN_ID=5003

# Contract addresses (filled after deployment — see README for live values)
NEXT_PUBLIC_ROUND_MANAGER_ADDRESS=
NEXT_PUBLIC_PREDICTION_REGISTRY_ADDRESS=
NEXT_PUBLIC_LEADERBOARD_ADDRESS=
NEXT_PUBLIC_AGENT_REGISTRY_ADDRESS=
NEXT_PUBLIC_GAUNTLET_LEADERBOARD_ADDRESS=
NEXT_PUBLIC_AGENT_NFT_ADDRESS=
NEXT_PUBLIC_BATTLE_RESULT_NFT_ADDRESS=

# Pyth / IPyth oracle adapter address on Mantle Sepolia
NEXT_PUBLIC_PYTH_ADDRESS=

# Axiom-7 agent wallet (public address; used to read its on-chain predictions)
NEXT_PUBLIC_AGENT_WALLET=

# Server-only — Axiom-7's private key. NEVER expose to the client.
# Used by /api/bot-predict and /api/bot-signal to sign the agent's predictions.
BOT_PRIVATE_KEY=

NEXT_PUBLIC_APP_URL=
